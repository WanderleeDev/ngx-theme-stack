    "@angular/cli": "^21.0.1",
    "@angular/compiler-cli": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^10.0.1",
    "@schematics/angular": "^21.2.6",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-eslint": "21.3.1",
    "copyfiles": "^2.4.1",
    "eslint": "^10.0.3",
    "jsdom": "^28.0.0",
    "ng-packagr": "^21.2.0",
    "ngx-theme-stack": "workspace:*",
