{
  "name": "ngx-theme-stack",
  "version": "0.0.8",
  "scripts": {
    "build": "tsc -p tsconfig.schematics.json",
    "postbuild": "copyfiles schematics/collection.json schematics/package.json ../../dist/ngx-theme-stack/schematics/ --up 1 && copyfiles schematics/*/schema.json ../../dist/ngx-theme-stack/schematics/ --up 1"
  },
  "peerDependencies": {
    "@angular/common": "^21.2.0",
    "@angular/core": "^21.2.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.1.0",
    "tslib": "^2.3.0"
  },
  "license": "MIT",
  "sideEffects": false,
  "schematics": "./schematics/collection.json",
  "ng-add": {
    "save": "dependencies"
  },
  "devDependencies": {
    "copyfiles": "file:../../node_modules/copyfiles",
    "typescript": "file:../../node_modules/typescript"
  }
}

